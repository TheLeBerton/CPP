CC := c++
CFLAGS := -Wall -Wextra -Werror -std=c++98

SRCS := main.cpp ClapTrap.cpp
OBJS := $(SRCS:.cpp=.o)
HEAD := ClapTrap.hpp

NAME := clapTrap

all: $(NAME)

$(NAME): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $^


%.o: %.cpp $(HEAD)
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f $(OBJS)

fclean: clean
	rm -f $(NAME)

re: fclean all

t: all
	./$(NAME)

.PHONY: all clean fclean re

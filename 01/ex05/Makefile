CC := c++
CFLAGS := -Wall -Wextra -Werror -std=c++98

SRCS := main.cpp main.cpp Harl.cpp
OBJS := $(SRCS:.cpp=.o)
HEAD := Harl.hpp

NAME := harl

all: $(NAME)

$(NAME): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $^


%.o: %.cpp $(HEAD)
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f $(OBJS)

fclean: clean
	rm -f $(NAME)

re: fclean all

test: all
	@./$(NAME)


.PHONY: all clean fclean re
